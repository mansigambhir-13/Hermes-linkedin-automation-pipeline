# ── Anthropic = the entire LLM layer (validate / chat / adapt / refine / smart hashtags) ──
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
# ── fal.ai images — ONLY for /draft AI generation, which is DISABLED in prod. Leave empty for v1. ──
IMAGE_ADAPTER=fal
FAL_API_KEY=
# AI image hardening (all optional; sensible defaults):
#   IMAGE_TIMEOUT_MS       per-generate hard timeout (default 90000)
#   IMAGE_FALLBACK_ADAPTER opt-in secondary if the primary fails: fal | gateway | stub (default: none)
#   FAL_ATTEMPT_TIMEOUT_MS per-attempt timeout inside fal's retry loop (default 60000)
# IMAGE_TIMEOUT_MS=90000
# IMAGE_FALLBACK_ADAPTER=
# FAL_ATTEMPT_TIMEOUT_MS=60000

# ── Deterministic renderer (@rss/render — HTML→Chromium typeset cards; no network, fonts bundled) ──
# Needs Chromium: `pnpm --filter @rss/render exec playwright install --with-deps chromium` (Dockerfile does this).
#   RENDER_CONCURRENCY  max pages rendering at once (default 4)
#   RENDER_TIMEOUT_MS   per-render hard timeout (default 30000)
# RENDER_CONCURRENCY=4
# RENDER_TIMEOUT_MS=30000

# Visual mode for the compose pipeline (every /draft): render (DEFAULT — deterministic typeset cards, no fal
# key, on-brand, free) | ai (legacy wordless fal images, needs FAL_API_KEY) | hybrid (AI background + typeset
# overlay, needs FAL_API_KEY). Per-draft override also available via ComposeInput.visualMode.
# VISUAL_MODE=render

# ── Content library (the /posts picker source: pre-made posts the team feeds in) ──
# folder (default): reads CONTENT_LIBRARY_DIR ; supabase: reads the library_posts table (needs DATABASE_URL).
# A file in CONTENT_LIBRARY_DIR = publishable. Override to "Sample content" for the glossary set.
CONTENT_LIBRARY=folder
CONTENT_LIBRARY_DIR=content/ready
# Seed the DB from the folder: pnpm --filter @rss/core db:migrate && pnpm --filter @rss/core seed-library

# ── Database (Supabase / Postgres) ──
DATABASE_URL=

# ── Object storage (media) ──
# local  = dev filesystem (no creds; text-only is fine).
# supabase = Supabase Storage (prod) — portable public URLs; needs SUPABASE_SERVICE_ROLE_KEY to upload.
OBJECT_STORE=supabase
LOCAL_ARTIFACTS_DIR=.artifacts
SUPABASE_URL=https://ceknijyoqvngevzexcmo.supabase.co
SUPABASE_BUCKET=post-media
# Supabase → Settings → API → service_role (secret). Only needed to upload/serve images.
SUPABASE_SERVICE_ROLE_KEY=

# ── Config (non-secret) ──
# Team-supplied locked config; copy config/locked-config.example.json → config/locked-config.json
LOCKED_CONFIG_PATH=config/locked-config.json

# ── Slack (review/publish surface — apps/slack-bot) ──
SLACK_BOT_TOKEN=                    # xoxb-… (bot scopes: commands, chat:write, files:write)
SLACK_SIGNING_SECRET=              # required only for HTTP mode
# App-level token (xapp-…, scope connections:write). If set, the bot runs in SOCKET MODE — no public
# Request URL / tunnel needed; /draft + buttons + modals all work. Create it under Basic Information →
# App-Level Tokens after enabling Socket Mode. See infra/slack-setup.md.
SLACK_APP_TOKEN=
# Governance (optional): comma-separated Slack user IDs allowed to Approve/Publish. Empty = open to all.
SLACK_APPROVERS=
# Web intake (the bot serves apps/web at SLACK_INTAKE_PORT): channel ID where web-submitted drafts post for review (/invite @hermes there).
SLACK_INTAKE_CHANNEL=
SLACK_INTAKE_PORT=3002
# Ops alerts channel ID for publish failures; empty = post to the review channel only.
SLACK_OPS_CHANNEL=

# ── Durability + scheduling worker ──
# Draft store: file (default, durable, shared with the worker) | supabase (prod, needs DATABASE_URL) | memory (tests).
# For Supabase: set DRAFT_STORE=supabase + DATABASE_URL, then `pnpm --filter @rss/core db:migrate`.
DRAFT_STORE=file
DRAFT_STORE_PATH=.data/drafts.json
# Scheduling worker (apps/worker) poll interval, ms.
WORKER_INTERVAL_MS=30000
# Per-user /draft rate limit per hour (protects fal/Bedrock spend); 0 disables.
DRAFT_RATE_LIMIT_PER_HOUR=20

# ── Publishing (Phase 5 go-live) ──
# Transport: 'stub' (dev, no external calls) | 'live'/'postiz' (Postiz if POSTIZ_API_KEY set) | 'direct' (force the
# direct LinkedIn/IG adapters even when a Postiz key is present).
PUBLISHER_ADAPTER=live              # 'stub' simulates success in dev

# ── Postiz (preferred one-click backend: owns OAuth + media + publishing) ──
# Key: Postiz → Settings → Developers → Public API. Header is the key verbatim (no 'Bearer').
POSTIZ_API_KEY=
POSTIZ_API_URL=https://api.postiz.com/public/v1   # self-hosted: {BACKEND_URL}/public/v1
# Connected channel ids — list them with `pnpm --filter @rss/publisher postiz-channels`.
POSTIZ_INTEGRATION_LINKEDIN=
POSTIZ_INTEGRATION_X=
POSTIZ_INTEGRATION_INSTAGRAM=

# LinkedIn (single + MultiImage carousel; document = PDF-style carousel)
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=                # urn:li:organization:<id> or urn:li:person:<id>
LINKEDIN_VERSION=202605            # LinkedIn-Version header (YYYYMM)
# LinkedIn token refresh — populate to enable `pnpm --filter @rss/publisher refresh-tokens linkedin`.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REFRESH_TOKEN=
# Instagram Graph API (gated on Meta app review)
IG_USER_ID=
META_ACCESS_TOKEN=
META_GRAPH_BASE=https://graph.facebook.com/v25.0
# Meta token refresh — populate to enable `pnpm --filter @rss/publisher refresh-tokens meta`.
META_APP_ID=
META_APP_SECRET=
