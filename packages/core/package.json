{
  "name": "@rss/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*.ts"
  },
  "scripts": {
    "db:migrate": "cd ../.. && node --env-file=.env --import tsx packages/core/scripts/migrate.ts",
    "db:check": "cd ../.. && node --env-file=.env --import tsx packages/core/scripts/check.ts",
    "seed-library": "cd ../.. && node --env-file=.env --import tsx packages/core/scripts/seed-library.ts",
    "seed-glossary": "cd ../.. && node --env-file=.env --import tsx packages/core/scripts/seed-glossary.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "postgres": "^3.4.5",
    "zod": "^3.25.0"
  }
}
